FROM python:3.11-slim

WORKDIR /app

# Copy frontend files
COPY frontend/ .

# Make entrypoint script executable
RUN chmod +x entrypoint.sh

# Expose port
EXPOSE 8080

# Use startup script to inject environment variables into static files
ENTRYPOINT ["/app/entrypoint.sh"]

# Serve static files on 0.0.0.0 to allow external connections
CMD ["python", "-m", "http.server", "--bind", "0.0.0.0", "--directory", "/app", "8080"]
